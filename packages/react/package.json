{
  "name": "area-mockups",
  "version": "0.1.0",
  "description": "Interactive, GPU-accelerated 3D device mockups for React. Drop any content onto the screen of a 3D phone — it stays fully live. React binding of @area-mockups/core.",
  "keywords": [
    "react",
    "threejs",
    "react-three-fiber",
    "drei",
    "3d",
    "mockup",
    "device",
    "phone",
    "smartphone",
    "webgl",
    "gpu"
  ],
  "license": "MIT",
  "author": "subwaymatch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subwaymatch/area-mockups.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/subwaymatch/area-mockups#readme",
  "bugs": {
    "url": "https://github.com/subwaymatch/area-mockups/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup"
  },
  "peerDependencies": {
    "@react-three/drei": ">=10",
    "@react-three/fiber": ">=9",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160.0"
  },
  "devDependencies": {
    "@area-mockups/core": "0.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/react": "^19.2.17",
    "@types/three": "^0.185.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
